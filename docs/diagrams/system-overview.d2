direction: right

**: {
  &leaf: true
  style.fill: "#FFFFFF"
  style.stroke: "#CBD5E1"
  style.font-color: "#334155"
  style.border-radius: 8
}

classes: {
  person: {
    shape: person
    style.fill: "#F8FAFC"
    style.stroke: "#64748B"
    style.font-color: "#0F172A"
    style.stroke-width: 2
  }
  owned: {
    style.fill: "#ECF7F0"
    style.stroke: "#397A5A"
    style.font-color: "#173C2B"
    style.border-radius: 14
    style.stroke-width: 2
    style.shadow: true
  }
  external: {
    style.fill: "#FFF8E8"
    style.stroke: "#B7791F"
    style.font-color: "#5F3B0B"
    style.border-radius: 14
    style.stroke-width: 2
  }
  data: {
    shape: cylinder
    style.fill: "#EDF4FF"
    style.stroke: "#4776B5"
    style.font-color: "#173B68"
    style.stroke-width: 2
  }
}

student: 学生 {class: person}
operator: 运营人员 {class: person}

myleafy: MyLeafy 系统边界 {
  class: owned
  direction: down

  ios: MyLeafy iOS {
    class: owned
    scope: 课表 · 校园 · 社区 · AI
  }

  local: 设备本地数据 {
    class: data
  }

  web: 官网与运营后台 {
    class: owned
    scope: 公开页面 · 分享 · 内容治理
  }

  ios -> local: 读写本地状态
}

school: 学校教务系统 {
  class: external
  scope: 身份 · 课表 · 成绩 · 考试
}

supabase: Supabase 业务后端 {
  class: external
  scope: Auth · Database · Storage · Functions
}

student -> myleafy.ios: 日常学习与校园任务
operator -> myleafy.web: 受控运营
myleafy.ios -> school: 授权访问教务数据
myleafy.ios -> supabase: 用户会话 + RLS
myleafy.web -> supabase: 管理代理 + 服务端授权

legend: 图例 {
  near: bottom-right
  style.fill: "#FFFFFF"
  style.stroke: "#CBD5E1"
  style.font-color: "#475569"
  style.border-radius: 10
  grid-columns: 3
  owned: MyLeafy 负责 {class: owned}
  external: 外部依赖 {class: external}
  data: 设备数据 {class: data}
}
