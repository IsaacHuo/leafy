direction: down

root: MyLeafy {
  grid-columns: 2
  leafy: Leafy AI {
    chat: 对话与本机学业上下文
    artifacts: 报告、清单与导出
  }
  timetable: 课表 {
    week: 周课表与课程详情
    scope: 时间范围与日程叠加
    share: 分享图与 Widget
  }
  community: 社区 {
    feed: 帖子、投票与互动
    notices: 通知与公告
    publish: 发布与个人内容
  }
  academics: 学业 {
    cultivation: 教学培养
    schedule: 时间日程
    classrooms: 空闲教室
    learning: 学习空间
    more: 体育、职业、考研、评价等
  }
  profile: 我的 {
    identity: 社区资料与邮箱绑定
    sharing: 共享课表
    settings: 外观、语言与数据设置
    support: 支持与关于
  }
}
